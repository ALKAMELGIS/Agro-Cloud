{
  "name": "agri-cloud",
  "private": true,
  "version": "0.1.0",
  "description": "Agri Cloud",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:clean": "concurrently \"npm run dev:client:clean\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "node --watch server/index.js",
    "dev:client:clean": "vite --force",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "overrides": {
    "vite": {
      "rollup": "4.60.0"
    }
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@tmcw/togeojson": "^7.1.2",
    "@vitejs/plugin-react": "^5.2.0",
    "cors": "^2.8.6",
    "express": "^4.22.1",
    "jszip": "^3.10.1",
    "leaflet": "^1.9.4",
    "leaflet-draw": "^1.0.4",
    "mapbox-gl": "^3.23.0",
    "maplibre-gl": "^5.24.0",
    "openai": "^6.35.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-leaflet": "^5.0.0",
    "react-map-gl": "^8.1.1",
    "react-router-dom": "^7.14.2",
    "react-to-print": "^3.3.0",
    "shpjs": "^6.2.0",
    "vite": "^7.3.2",
    "vite-plugin-pwa": "^1.2.0",
    "ws": "^8.20.0",
    "yup": "^1.7.1"
  }
}
